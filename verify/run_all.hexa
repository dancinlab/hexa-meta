fn main() {
    println("========================================================================")
    println("  hexa-meta verify/run_all — meta-layer verification sweep")
    println("========================================================================")
    let mut ran = 0
    let mut rc_zero = 0
    let mut rc_nonzero = 0
    let mut stub_seen = 0
    for s in SCRIPTS {
        ran = ran + 1
        let rc_str = exec("hexa run " + s + " >/tmp/_hexa_meta_v.out 2>&1; echo $?").trim()
        let rc = int(rc_str)
        let out = exec("cat /tmp/_hexa_meta_v.out 2>/dev/null")
        let is_stub = out.contains("STUB:")
        if is_stub {
            stub_seen = stub_seen + 1
        }
        if rc == 0 {
            rc_zero = rc_zero + 1
        } else {
            rc_nonzero = rc_nonzero + 1
            println("")
            println("---- " + s + " (rc=" + str(rc) + ") ----")
            let lines = out.split("\n")
            let n = lines.len()
            let mut start = 0
            if n > 6 { start = n - 6 }
            let mut k = start
            while k < n {
                println(lines[k])
                k = k + 1
            }
        }
    }
    println("")
    println("========================================================================")
    println("  ran=" + str(ran) + "  rc=0:" + str(rc_zero) + "  rc!=0:" + str(rc_nonzero) + "  stub-tagged:" + str(stub_seen))
    println("========================================================================")
    if rc_nonzero > 0 {
        println("  verify sweep FAILED — see per-script tails above.")
        exit(1)
    }
    println("  PASS — all " + str(ran) + " predictions/verify_*.hexa scripts executed rc=0.")
    println("  (See per-script logs for internal PASS/FAIL/MISS counts.)")
}
